{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Embedded Notes","text":"<p>\u041f\u0440\u0430\u043a\u0442\u0438\u0447\u043d\u0456 \u043d\u043e\u0442\u0430\u0442\u043a\u0438 \u0437 \u043c\u0456\u043a\u0440\u043e\u043a\u043e\u043d\u0442\u0440\u043e\u043b\u0435\u0440\u0456\u0432, STM32, \u0435\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u0456\u043a\u0438 \u0442\u0430 embedded \u0440\u043e\u0437\u0440\u043e\u0431\u043a\u0438. \u0426\u0435\u0439 \u0441\u0430\u0439\u0442 \u2014 \u0456\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0438\u0439 \u0440\u043e\u0431\u043e\u0447\u0438\u0439 \u0436\u0443\u0440\u043d\u0430\u043b, \u0430 \u043d\u0435 \u0442\u0435\u043e\u0440\u0435\u0442\u0438\u0447\u043d\u0438\u0439 \u043a\u0443\u0440\u0441. \u0421\u0430\u043c\u0430 \u0437\u043d\u0430\u0445\u043e\u0434\u0436\u0443\u0441\u044c \u0432 \u043f\u0440\u043e\u0446\u0435\u0441\u0456 \u043d\u0430\u0432\u0447\u0430\u043d\u043d\u044f.</p>"},{"location":"#arduino","title":"\u26a1 Arduino","text":"<p>\u0428\u0432\u0438\u0434\u043a\u0456 \u043f\u0440\u043e\u0442\u043e\u0442\u0438\u043f\u0438</p> <p>\u2192 \u041f\u0435\u0440\u0435\u0439\u0442\u0438 \u0434\u043e Arduino</p>"},{"location":"#stm32","title":"\ud83e\udde0 STM32","text":"<p>\u041f\u0440\u043e\u0444\u0435\u0441\u0456\u0439\u043d\u0430 \u0440\u043e\u0431\u043e\u0442\u0430 \u0437 \u043c\u0456\u043a\u0440\u043e\u043a\u043e\u043d\u0442\u0440\u043e\u043b\u0435\u0440\u0430\u043c\u0438 ST</p> <p>\u2192 \u041f\u0435\u0440\u0435\u0439\u0442\u0438 \u0434\u043e STM32</p>"},{"location":"arduino/","title":"Arduino UNO \u2014 \u0417\u0430\u043d\u044f\u0442\u0442\u044f 1","text":""},{"location":"arduino/#_1","title":"\ud83c\udfaf \u041c\u0435\u0442\u0430 \u0437\u0430\u043d\u044f\u0442\u0442\u044f","text":"<p>\u041e\u0437\u043d\u0430\u0439\u043e\u043c\u0438\u0442\u0438\u0441\u044f \u0437 Arduino Uno, \u0446\u0438\u0444\u0440\u043e\u0432\u0438\u043c\u0438 \u043f\u0456\u043d\u0430\u043c\u0438 \u0442\u0430 \u0431\u0430\u0437\u043e\u0432\u0438\u043c \u043a\u0435\u0440\u0443\u0432\u0430\u043d\u043d\u044f\u043c \u0441\u0432\u0456\u0442\u043b\u043e\u0434\u0456\u043e\u0434\u0430\u043c\u0438.</p>"},{"location":"arduino/#_2","title":"\ud83d\udcda \u0422\u0435\u043e\u0440\u0435\u0442\u0438\u0447\u043d\u0438\u0439 \u043c\u0430\u0442\u0435\u0440\u0456\u0430\u043b","text":"<ul> <li>Arduino Uno \u2014 \u0430\u043f\u0430\u0440\u0430\u0442\u043d\u0430 \u0447\u0430\u0441\u0442\u0438\u043d\u0430</li> <li>\u0426\u0438\u0444\u0440\u043e\u0432\u0456 \u0442\u0430 \u0430\u043d\u0430\u043b\u043e\u0433\u043e\u0432\u0456 \u0432\u0445\u043e\u0434\u0438/\u0432\u0438\u0445\u043e\u0434\u0438</li> <li>Breadboard \u0442\u0430 \u043f\u0456\u0434\u043a\u043b\u044e\u0447\u0435\u043d\u043d\u044f</li> <li>\u0417\u0430\u043a\u043e\u043d \u041e\u043c\u0430 \u0432 \u043f\u0440\u0430\u043a\u0442\u0438\u0446\u0456</li> </ul>"},{"location":"arduino/#_3","title":"\ud83e\uddea \u041f\u0440\u0430\u043a\u0442\u0438\u0447\u043d\u0456 \u0440\u043e\u0431\u043e\u0442\u0438","text":"<ul> <li>\u041c\u0438\u0433\u043e\u0442\u0456\u043d\u043d\u044f \u0441\u0432\u0456\u0442\u043b\u043e\u0434\u0456\u043e\u0434\u043e\u043c</li> <li>\u0421\u0432\u0456\u0442\u043b\u043e\u0444\u043e\u0440</li> </ul>"},{"location":"arduino/#_4","title":"\ud83e\udde0 \u0417\u0430\u0432\u0434\u0430\u043d\u043d\u044f","text":"<ul> <li>\u041c\u043e\u0440\u0437\u0435 \u043a\u043e\u0434 (\u0441\u0432\u0456\u0442\u043b\u043e\u0434\u0456\u043e\u0434)</li> <li>\u041e\u0434\u043d\u043e\u0447\u0430\u0441\u043d\u0435 \u043a\u0435\u0440\u0443\u0432\u0430\u043d\u043d\u044f LED</li> <li>\u0420\u043e\u0437\u0448\u0438\u0440\u0435\u043d\u0438\u0439 \u0441\u0432\u0456\u0442\u043b\u043e\u0444\u043e\u0440</li> <li>\u041f\u0456\u0448\u043e\u0445\u0456\u0434\u043d\u0438\u0439 \u0441\u0432\u0456\u0442\u043b\u043e\u0444\u043e\u0440</li> </ul>"},{"location":"arduino/#_5","title":"\ud83d\udcce \u041c\u0430\u0442\u0435\u0440\u0456\u0430\u043b\u0438 \u0437\u0430\u043d\u044f\u0442\u0442\u044f","text":"<ul> <li>Arduino Uno</li> <li>Breadboard</li> <li>LED</li> <li>\u0420\u0435\u0437\u0438\u0441\u0442\u043e\u0440 220\u03a9</li> </ul>"},{"location":"arduino/#_6","title":"\ud83e\udded \u0420\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u043e\u0432\u0430\u043d\u0438\u0439 \u043f\u043e\u0440\u044f\u0434\u043e\u043a","text":"<ol> <li>\u0422\u0435\u043e\u0440\u0456\u044f</li> <li>Blink LED</li> <li>\u0421\u0432\u0456\u0442\u043b\u043e\u0444\u043e\u0440</li> <li>\u0414\u043e\u043c\u0430\u0448\u043d\u0454 \u0437\u0430\u0432\u0434\u0430\u043d\u043d\u044f</li> </ol>"},{"location":"arduino/theory-arduino-uno/","title":"\u041f\u043b\u0430\u0442\u0430 Ardion UNO \u0442\u0430 \u0457\u0457 \u043e\u0441\u043e\u0431\u043b\u0438\u0432\u043e\u0441\u0442\u0456","text":"<p>\u041c\u0435\u0442\u0430: \u041e\u0437\u043d\u0430\u0439\u043e\u043c\u0438\u0442\u0438\u0441\u044f \u0437 \u0445\u0430\u0440\u0430\u043a\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043a\u0430\u043c\u0438 \u0442\u0430 \u0440\u043e\u0431\u043e\u0442\u043e\u044e \u043c\u0456\u043a\u0440\u043e\u043a\u043e\u043d\u0442\u0440\u043e\u043b\u0435\u0440\u0430 Arduino Uno.</p> <p>Arduino \u2013 \u0430\u043f\u0430\u0440\u0430\u0442\u043d\u0430 \u043e\u0431\u0447\u0438\u0441\u043b\u044e\u0432\u0430\u043b\u044c\u043d\u0430 \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u0430, \u043e\u0441\u043d\u043e\u0432\u043d\u0438\u043c\u0438 \u043a\u043e\u043c\u043f\u043e\u043d\u0435\u043d\u0442\u0430\u043c\u0438 \u044f\u043a\u043e\u0457 \u0454 \u043f\u043b\u0430\u0442\u0430 \u0432\u0432\u043e\u0434\u0443/\u0432\u0438\u0432\u043e\u0434\u0443 \u0442\u0430 \u0441\u0435\u0440\u0435\u0434\u043e\u0432\u0438\u0449\u0435 \u0440\u043e\u0437\u0440\u043e\u0431\u043a\u0438 \u043d\u0430 \u043c\u043e\u0432\u0456 Processing/Wiring.</p> <p>Arduino \u0437\u0430\u0441\u0442\u043e\u0441\u043e\u0432\u0443\u0454\u0442\u044c\u0441\u044f \u0434\u043b\u044f \u0441\u0442\u0432\u043e\u0440\u0435\u043d\u043d\u044f \u0435\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u0438\u0445 \u043f\u0440\u0438\u0441\u0442\u0440\u043e\u0457\u0432 \u0437 \u043c\u043e\u0436\u043b\u0438\u0432\u0456\u0441\u0442\u044e \u043e\u0442\u0440\u0438\u043c\u0430\u043d\u043d\u044f \u0441\u0438\u0433\u043d\u0430\u043b\u0456\u0432 \u0432\u0456\u0434 \u0440\u0456\u0437\u043d\u0438\u0445 \u043a\u0435\u0440\u0443\u044e\u0447\u0438\u0445 \u0435\u043b\u0435\u043c\u0435\u043d\u0442\u0456\u0432 (\u0441\u0435\u043d\u0441\u043e\u0440\u0438, \u043a\u043d\u043e\u043f\u043a\u0438 \u0442\u043e\u0449\u043e) \u0456 \u0443\u043f\u0440\u0430\u0432\u043b\u0456\u043d\u043d\u044f \u0440\u0456\u0437\u043d\u0438\u043c\u0438 \u0432\u0438\u043a\u043e\u043d\u0430\u0432\u0447\u0438\u043c\u0438 \u043f\u0440\u0438\u0441\u0442\u0440\u043e\u044f\u043c\u0438 (\u043b\u0430\u043c\u043f\u043e\u0447\u043a\u0438, \u0434\u0432\u0438\u0433\u0443\u043d\u0438 \u0442\u043e\u0449\u043e). </p> <p>\u041e\u0440\u0438\u0433\u0456\u043d\u0430\u043b\u044c\u043d\u0456 \u043f\u043b\u0430\u0442\u0438 Arduino \u0432\u0438\u0440\u043e\u0431\u043b\u044f\u044e\u0442\u044c\u0441\u044f \u0444\u0456\u0440\u043c\u043e\u044e SmartProjects. \u041d\u0430 \u0434\u0430\u043d\u0438\u0439 \u043c\u043e\u043c\u0435\u043d\u0442 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e 20 \u0432\u0435\u0440\u0441\u0456\u0439 \u043f\u043b\u0430\u0442, \u044f\u043a\u0456 \u0440\u0456\u0437\u043d\u044f\u0442\u044c\u0441\u044f \u0445\u0430\u0440\u0430\u043a\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043a\u0430\u043c\u0438 \u043c\u0456\u043a\u0440\u043e\u043a\u043e\u043d\u0442\u0440\u043e\u043b\u0435\u0440\u0430 \u0442\u0430 \u043a\u0456\u043b\u044c\u043a\u0456\u0441\u0442\u044e \u0430\u043d\u0430\u043b\u043e\u0433\u043e\u0432\u0438\u0445 \u0456 \u0446\u0438\u0444\u0440\u043e\u0432\u0438\u0445 \u0432\u0438\u0432\u043e\u0434\u0456\u0432. </p> <p>\u041d\u0430\u0439\u043f\u043e\u043f\u0443\u043b\u044f\u0440\u043d\u0456\u0448\u043e\u044e \u0432\u0435\u0440\u0441\u0456\u0454\u044e Arduino \u0454 Arduino Uno (\u0440\u0438\u0441. 1), \u044f\u043a\u0438\u0439 \u043f\u043e\u0431\u0443\u0434\u043e\u0432\u0430\u043d\u0438\u0439 \u043d\u0430 \u043e\u0441\u043d\u043e\u0432\u0456 \u043c\u0456\u043a\u0440\u043e\u043a\u043e\u043d\u0442\u0440\u043e\u043b\u0435\u0440\u0430 ATmega328P \u0444\u0456\u0440\u043c\u0438 Atmel (1 \u043d\u0430 \u0440\u0438\u0441. 1). </p> <p></p> \u041f\u043b\u0430\u0442\u0430 Arduino Uno: 1 \u2013 \u043c\u0456\u043a\u0440\u043e\u043a\u043e\u043d\u0442\u0440\u043e\u043b\u0435\u0440; 2 \u2013 \u043a\u043d\u043e\u043f\u043a\u0430 \u0441\u043a\u0438\u0434\u0430\u043d\u043d\u044f; 3 \u2013 \u043f\u043e\u0440\u0442 USB; 4 \u2013 \u0436\u0438\u0432\u043b\u0435\u043d\u043d\u044f 5\u0412  \u041e\u0441\u043d\u043e\u0432\u043d\u0456 \u0445\u0430\u0440\u0430\u043a\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043a\u0438 \u043f\u043b\u0430\u0442\u0430 Arduino Uno <p> <p> \u0425\u0430\u0440\u0430\u043a\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043a\u0438 Arduino Uno </p> \u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440 \u0417\u043d\u0430\u0447\u0435\u043d\u043d\u044f \u0420\u043e\u0431\u043e\u0447\u0430 \u043d\u0430\u043f\u0440\u0443\u0433\u0430 5 \u0412 \u0412\u0445\u0456\u0434\u043d\u0430 \u043d\u0430\u043f\u0440\u0443\u0433\u0430 (\u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u043e\u0432\u0430\u043d\u0430) 7-12 \u0412 \u0412\u0445\u0456\u0434\u043d\u0430 \u043d\u0430\u043f\u0440\u0443\u0433\u0430 (\u0433\u0440\u0430\u043d\u0438\u0447\u043d\u0430) 20 \u0412 \u041a\u0456\u043b\u044c\u043a\u0456\u0441\u0442\u044c \u0446\u0438\u0444\u0440\u043e\u0432\u0438\u0445 \u0432\u0445\u043e\u0434\u0456\u0432/\u0432\u0438\u0445\u043e\u0434\u0456\u0432 14 (6 \u0437 \u043d\u0438\u0445 \u043c\u043e\u0436\u0443\u0442\u044c \u0431\u0443\u0442\u0438 \u0432 \u0440\u043e\u043b\u0456 \u0428\u0406\u041c) \u041a\u0456\u043b\u044c\u043a\u0456\u0441\u0442\u044c \u0430\u043d\u0430\u043b\u043e\u0433\u043e\u0432\u0438\u0445 \u0432\u0445\u043e\u0434\u0456\u0432/\u0432\u0438\u0445\u043e\u0434\u0456\u0432 6 \u041f\u043e\u0441\u0442\u0456\u0439\u043d\u0438\u0439 \u0441\u0442\u0440\u0443\u043c \u0447\u0435\u0440\u0435\u0437 \u0432\u0445\u0456\u0434/\u0432\u0438\u0445\u0456\u0434 40 \u043c\u0410 \u041f\u043e\u0441\u0442\u0456\u0439\u043d\u0438\u0439 \u0441\u0442\u0440\u0443\u043c \u0434\u043b\u044f \u0432\u0438\u0445\u043e\u0434\u0443 3.3V 50 \u043c\u0410 \u0424\u043b\u0435\u0448-\u043f\u0430\u043c\u2019\u044f\u0442\u044c (0,5 \u041a\u0431 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u044e\u0442\u044c\u0441\u044f \u0434\u043b\u044f \u0437\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0443\u0432\u0430\u0447\u0430) 32 \u041a\u0431 (ATmega328P) \u041e\u0417\u041f 2 \u041a\u0431 (ATmega328P) \u0422\u0430\u043a\u0442\u043e\u0432\u0430 \u0447\u0430\u0441\u0442\u043e\u0442\u0430 16 \u041c\u0413\u0446 <p>\u0417\u0433\u0456\u0434\u043d\u043e \u0437 \u043d\u0430\u0432\u0435\u0434\u0435\u043d\u0438\u043c\u0438 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u0430\u043c\u0438, \u043d\u0430\u043f\u0440\u0443\u0433\u0430 \u0437\u043e\u0432\u043d\u0456\u0448\u043d\u044c\u043e\u0433\u043e \u0434\u0436\u0435\u0440\u0435\u043b\u0430 \u0436\u0438\u0432\u043b\u0435\u043d\u043d\u044f \u043c\u043e\u0436\u0435 \u0431\u0443\u0442\u0438 \u0432 \u043c\u0435\u0436\u0430\u0445 \u0432\u0456\u0434 6 \u0434\u043e 20 \u0412, \u043e\u0434\u043d\u0430\u043a, \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0454\u0442\u044c\u0441\u044f \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u0434\u0436\u0435\u0440\u0435\u043b\u043e \u0436\u0438\u0432\u043b\u0435\u043d\u043d\u044f \u0437 \u043d\u0430\u043f\u0440\u0443\u0433\u043e\u044e \u0432 \u0434\u0456\u0430\u043f\u0430\u0437\u043e\u043d\u0456 \u0432\u0456\u0434 7 \u0434\u043e 12 \u0412, \u0430\u0434\u0436\u0435 \u043d\u0438\u0436\u0447\u0435 7 \u0412 \u043d\u0430\u043f\u0440\u0443\u0433\u0430 \u043d\u0430 \u0432\u0438\u0432\u043e\u0434\u0456 5V \u0437\u043d\u0438\u0437\u0438\u0442\u044c\u0441\u044f \u0456 \u0446\u0435 \u043c\u043e\u0436\u0435 \u0441\u0442\u0430\u0442\u0438 \u043f\u0440\u0438\u0447\u0438\u043d\u043e\u044e \u043d\u0435\u0441\u0442\u0430\u0431\u0456\u043b\u044c\u043d\u043e\u0457 \u0440\u043e\u0431\u043e\u0442\u0438 \u043f\u0440\u0438\u0441\u0442\u0440\u043e\u044e, \u0431\u0456\u043b\u044c\u0448\u0435 12 \u0412 \u043c\u043e\u0436\u0435 \u0432\u0438\u043a\u043b\u0438\u043a\u0430\u0442\u0438 \u043f\u0435\u0440\u0435\u0433\u0440\u0456\u0432 \u0441\u0442\u0430\u0431\u0456\u043b\u0456\u0437\u0430\u0442\u043e\u0440\u0430 \u043d\u0430\u043f\u0440\u0443\u0433\u0438 \u0432\u0438\u0445\u0456\u0434 \u043f\u043b\u0430\u0442\u0438 \u0437 \u043b\u0430\u0434\u0443. </p>"},{"location":"arduino/theory-arduino-uno/#power","title":"\u041a\u043e\u043d\u0442\u0430\u043a\u0442\u0438 \u0436\u0438\u0432\u043b\u0435\u043d\u043d\u044f (<code>POWER</code>):","text":"VIN \u041d\u0430\u043f\u0440\u0443\u0433\u0430, \u0449\u043e \u043d\u0430\u0434\u0445\u043e\u0434\u0438\u0442\u044c \u0432 Arduino \u0431\u0435\u0437\u043f\u043e\u0441\u0435\u0440\u0435\u0434\u043d\u044c\u043e \u0432\u0456\u0434 \u0437\u043e\u0432\u043d\u0456\u0448\u043d\u044c\u043e\u0433\u043e \u0434\u0436\u0435\u0440\u0435\u043b\u0430 \u0436\u0438\u0432\u043b\u0435\u043d\u043d\u044f (\u043d\u0435 \u043f\u043e\u0432'\u044f\u0437\u0430\u043d\u0435 \u0437 5\u0412 \u0432\u0456\u0434 USB \u0430\u0431\u043e \u0456\u043d\u0448\u0438\u043c \u0441\u0442\u0430\u0431\u0456\u043b\u0456\u0437\u043e\u0432\u0430\u043d\u043e\u044e \u043d\u0430\u043f\u0440\u0443\u0433\u043e\u044e). \u0427\u0435\u0440\u0435\u0437 \u0446\u0435\u0439 \u0432\u0438\u0432\u0456\u0434 \u043c\u043e\u0436\u043d\u0430 \u044f\u043a \u043f\u043e\u0434\u0430\u0432\u0430\u0442\u0438 \u0437\u043e\u0432\u043d\u0456\u0448\u043d\u0454 \u0436\u0438\u0432\u043b\u0435\u043d\u043d\u044f, \u0442\u0430\u043a \u0456 \u0441\u043f\u043e\u0436\u0438\u0432\u0430\u0442\u0438 \u0441\u0442\u0440\u0443\u043c, \u043a\u043e\u043b\u0438 \u043f\u0440\u0438\u0441\u0442\u0440\u0456\u0439 \u0436\u0438\u0432\u0438\u0442\u044c\u0441\u044f \u0432\u0456\u0434 \u0437\u043e\u0432\u043d\u0456\u0448\u043d\u044c\u043e\u0433\u043e \u0430\u0434\u0430\u043f\u0442\u0435\u0440\u0430. 5V \u041d\u0430 \u0446\u0435\u0439 \u0440\u043e\u0437'\u0454\u043c \u043d\u0430\u0434\u0445\u043e\u0434\u0438\u0442\u044c \u043d\u0430\u043f\u0440\u0443\u0433\u0430 5\u0412 \u0432\u0456\u0434 \u0441\u0442\u0430\u0431\u0456\u043b\u0456\u0437\u0430\u0442\u043e\u0440\u0430 \u043d\u0430\u043f\u0440\u0443\u0433\u0438, \u043d\u0435\u0437\u0430\u043b\u0435\u0436\u043d\u043e \u0432\u0456\u0434 \u0442\u043e\u0433\u043e, \u044f\u043a \u0436\u0438\u0432\u0438\u0442\u044c\u0441\u044f \u043f\u0440\u0438\u0441\u0442\u0440\u0456\u0439: \u0432\u0456\u0434 \u0430\u0434\u0430\u043f\u0442\u0435\u0440\u0430 (7 - 12\u0412), \u0432\u0456\u0434 USB (5\u0412) \u0430\u0431\u043e \u0447\u0435\u0440\u0435\u0437 \u0432\u0438\u0432\u0456\u0434 VIN (7 - 12\u0412). 3.3V 3.3\u0412, \u0449\u043e \u043d\u0430\u0434\u0445\u043e\u0434\u044f\u0442\u044c \u0432\u0456\u0434 \u0441\u0442\u0430\u0431\u0456\u043b\u0456\u0437\u0430\u0442\u043e\u0440\u0430 \u043d\u0430\u043f\u0440\u0443\u0433\u0438. \u041c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u0438\u0439 \u0441\u0442\u0440\u0443\u043c, \u0441\u043f\u043e\u0436\u0438\u0432\u0430\u043d\u0438\u0439 \u0432\u0456\u0434 \u0446\u044c\u043e\u0433\u043e \u0432\u0438\u0432\u043e\u0434\u0443, \u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u044c 50 \u043c\u0410. GND \u0412\u0438\u0432\u0456\u0434 \u0437\u0435\u043c\u043b\u0456 \u2013 \u0437\u0430\u0433\u0430\u043b\u044c\u043d\u0438\u0439 \u043a\u043e\u043d\u0442\u0430\u043a\u0442. <p>Danger</p> <p>\u0416\u0438\u0432\u0438\u0442\u0438 \u043f\u0440\u0438\u0441\u0442\u0440\u0456\u0439 \u0447\u0435\u0440\u0435\u0437 \u0432\u0438\u0432\u043e\u0434\u0438 5V \u0430\u0431\u043e 3V3 \u043d\u0435 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0454\u0442\u044c\u0441\u044f, \u043e\u0441\u043a\u0456\u043b\u044c\u043a\u0438 \u0432 \u0446\u044c\u043e\u043c\u0443 \u0432\u0438\u043f\u0430\u0434\u043a\u0443 \u043d\u0435 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0454\u0442\u044c\u0441\u044f \u0441\u0442\u0430\u0431\u0456\u043b\u0456\u0437\u0430\u0442\u043e\u0440 \u043d\u0430\u043f\u0440\u0443\u0433\u0438, \u0449\u043e \u043c\u043e\u0436\u0435 \u043f\u0440\u0438\u0432\u0435\u0441\u0442\u0438 \u0434\u043e \u0432\u0438\u0445\u043e\u0434\u0443 \u043f\u043b\u0430\u0442\u0438 \u0437 \u043b\u0430\u0434\u0443.</p>"},{"location":"arduino/theory-arduino-uno/#_1","title":"\u0426\u0438\u0444\u0440\u043e\u0432\u0456 \u0442\u0430 \u0430\u043d\u0430\u043b\u043e\u0433\u043e\u0432\u0456 \u0432\u0445\u043e\u0434\u0438 \u0456 \u0432\u0438\u0445\u043e\u0434\u0438","text":"<p>\u041d\u0430 \u0432\u0456\u0434\u043c\u0456\u043d\u0443 \u0432\u0456\u0434 \u043b\u044e\u0434\u0435\u0439, \u043a\u043e\u043c\u043f'\u044e\u0442\u0435\u0440\u0438 \u043f\u0440\u0430\u0446\u044e\u044e\u0442\u044c \u0442\u0430 \u0441\u043f\u0456\u043b\u043a\u0443\u044e\u0442\u044c\u0441\u044f \u0437\u0430 \u0434\u043e\u043f\u043e\u043c\u043e\u0433\u043e\u044e \u0434\u0432\u043e\u0445 \u0441\u0438\u043c\u0432\u043e\u043b\u0456\u0432: \u00ab1\u00bb \u0442\u0430 \u00ab0\u00bb. \u0426\u0435 \u0442\u0435, \u0449\u043e \u043d\u0430\u0437\u0438\u0432\u0430\u0454\u0442\u044c\u0441\u044f \u0446\u0438\u0444\u0440\u043e\u0432\u0438\u043c\u0438 \u0441\u0438\u0433\u043d\u0430\u043b\u0430\u043c\u0438. \u0412\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u044e\u0447\u0438 \u043a\u043e\u043c\u0431\u0456\u043d\u0430\u0446\u0456\u0457 \u0446\u0438\u0445 \u0434\u0432\u043e\u0445 \u0441\u0438\u043c\u0432\u043e\u043b\u0456\u0432, \u0446\u0438\u0444\u0440\u043e\u0432\u0456 \u043c\u0430\u0448\u0438\u043d\u0438 \u043c\u043e\u0436\u0443\u0442\u044c \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u044f\u0442\u0438 \u043f\u0440\u0430\u043a\u0442\u0438\u0447\u043d\u043e \u0432\u0441\u0435 \u0443 \u0412\u0441\u0435\u0441\u0432\u0456\u0442\u0456</p> D2 ... D13 \u0426\u0438\u0444\u0440\u043e\u0432\u0456 \u0432\u0445\u043e\u0434\u0438/\u0432\u0438\u0445\u043e\u0434\u0438 \u0434\u0430\u044e\u0442\u044c \u043c\u043e\u0436\u043b\u0438\u0432\u0456\u0441\u0442\u044c \u043f\u0440\u0438\u0439\u043c\u0430\u0442\u0438 \u0430\u0431\u043e \u043f\u043e\u0434\u0430\u0432\u0430\u0442\u0438 \u043d\u0438\u0437\u044c\u043a\u0443 \u0447\u0438 \u0432\u0438\u0441\u043e\u043a\u0443 \u043d\u0430\u043f\u0440\u0443\u0433\u0443. \u041d\u0438\u0437\u044c\u043a\u0430 \u043d\u0430\u043f\u0440\u0443\u0433\u0430 (<code>LOW</code> \u0430\u0431\u043e <code>0</code>)  \u043e\u0437\u043d\u0430\u0447\u0430\u0454 \u0449\u043e \u043d\u0430 \u0446\u044c\u043e\u043c\u0443 \u043f\u0456\u043d\u0456 \u043d\u0430\u043f\u0440\u0443\u0433\u0430 \u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u044c \u0431\u043b\u0438\u0437\u044c\u043a\u043e 0 \u0432\u043e\u043b\u044c\u0442. \u0412\u0438\u0441\u043e\u043a\u0430 \u043d\u0430\u043f\u0440\u0443\u0433\u0430 (<code>HIGH</code>, <code>1</code>) \u043e\u0437\u043d\u0430\u0447\u0430\u0454 \u0449\u043e \u043d\u0430 \u043f\u0456\u043d\u0456 \u0431\u043b\u0438\u0437\u044c\u043a\u043e 5 \u0432\u043e\u043b\u044c\u0442. A0 ... A5 \u0410\u043d\u0430\u043b\u043e\u0433\u043e\u0432\u0456 \u0432\u0445\u043e\u0434\u0438 \u043c\u043e\u0436\u0443\u0442\u044c \u043f\u0440\u0438\u0439\u043c\u0430\u0442\u0438 \u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f \u043d\u0430\u043f\u0440\u0443\u0433\u0438 \u043d\u0435 \u0442\u0456\u043b\u044c\u043a\u0438 <code>0</code> \u0430\u0431\u043e <code>1</code>. \u0412\u043e\u043d\u0438 \u0434\u0430\u044e\u0442\u044c \u0437\u043c\u043e\u0433\u0443 \u0437\u0447\u0438\u0442\u0443\u0432\u0430\u0442\u0438 \u0456 \u043f\u0440\u043e\u043c\u0456\u0436\u043d\u0456 \u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f \u0432\u0456\u0434 0 \u0434\u043e 5 \u0432\u043e\u043b\u044c\u0442 \u043f\u0440\u0438\u0441\u0432\u043e\u0457\u0432\u0448\u0438 \u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f \u043d\u0430\u043f\u0440\u0443\u0437\u0456 \u0432\u0456\u0434 <code>0</code> \u0434\u043e <code>1023</code> \u043f\u043e\u0434\u0456\u043b\u043e\u043a.  \u041f\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043d\u043d\u044f \u043f\u043e\u0434\u0456\u043b\u043e\u043a \u0432 \u043d\u0430\u043f\u0440\u0443\u0433\u0443 <p>\u0422\u043e\u0431\u0442\u043e \u044f\u043a\u0449\u043e \u0437 \u043f\u043e\u0440\u0442\u0443 \u043e\u0442\u0440\u0438\u043c\u0443\u0454\u043c\u043e \u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f <code>1023</code> \u0442\u043e \u0446\u0435 \u043e\u0437\u043d\u0430\u0447\u0430\u0454, \u0449\u043e \u043d\u0430 \u0432\u0445\u043e\u0434\u0456 \u043d\u0430\u043f\u0440\u0443\u0433\u0430 5 \u0412, \u0442\u043e\u0434\u0456 \u0437\u0430 \u043f\u0440\u043e\u043f\u043e\u0440\u0446\u0456\u0454\u044e \u0437\u0430\u0432\u0436\u0434\u0438 \u043c\u043e\u0436\u043d\u0430 \u0432\u0438\u0437\u043d\u0430\u0447\u0438\u0442\u0438 \u043d\u0430\u043f\u0440\u0443\u0433\u0443 \\(V_A\\), \u0437\u043d\u0430\u044e\u0447\u0438 \u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f \u043d\u0430 \u0432\u0445\u043e\u0434\u0456 <code>AX</code>: $$ V_A = \\frac{5}{1023} \\cdot AX  \\tag{1.1} $$</p> \u0428\u0406\u041c \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u0438 \u041d\u0430 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u0438 \u043f\u043e\u0437\u043d\u0430\u0447\u0435\u043d\u0456  <code>~</code> (\u0434\u043b\u044f Arduino Uno \u0446\u0435 <code>D3</code>, <code>D5</code>, <code>D6</code>, <code>D9</code>, <code>D10</code>, <code>D11</code>) \u043c\u043e\u0436\u0443\u0442\u044c \u043f\u043e\u0434\u0430\u0432\u0430\u0442\u0438\u0441\u044f \u0437\u043d\u0430\u0447\u0435\u043d\u043d\u044f \u0432\u0456\u0434 <code>0</code> \u0434\u043e <code>255</code>.  \u0428\u0438\u0440\u043e\u0442\u043d\u043e-\u0456\u043c\u043f\u0443\u043b\u044c\u0441\u043d\u0430 \u043c\u043e\u0434\u0443\u043b\u044f\u0446\u0456 \u0446\u0435 \u043f\u0440\u043e\u0446\u0435\u0441 \u043a\u0435\u0440\u0443\u0432\u0430\u043d\u043d\u044f \u0448\u0438\u0440\u0438\u043d\u043e\u044e (\u0442\u0440\u0438\u0432\u0430\u043b\u0456\u0441\u0442\u044e) \u0456\u043c\u043f\u0443\u043b\u044c\u0441\u0456\u0432."},{"location":"electronics/","title":"\u041e\u0441\u043d\u043e\u0432\u0438 \u0435\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u0456\u043a\u0438","text":"<p>\u0426\u0435\u0439 \u0440\u043e\u0437\u0434\u0456\u043b \u043c\u0456\u0441\u0442\u0438\u0442\u044c \u0431\u0430\u0437\u043e\u0432\u0456 \u043f\u043e\u043d\u044f\u0442\u0442\u044f \u0435\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u0456\u043a\u0438, \u043d\u0435\u043e\u0431\u0445\u0456\u0434\u043d\u0456 \u0434\u043b\u044f \u0440\u043e\u0431\u043e\u0442\u0438 \u0437 \u043c\u0456\u043a\u0440\u043e\u043a\u043e\u043d\u0442\u0440\u043e\u043b\u0435\u0440\u0430\u043c\u0438 \u0442\u0430 \u043f\u043e\u0431\u0443\u0434\u043e\u0432\u0438 \u0435\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u0438\u0445 \u0441\u0445\u0435\u043c.</p> <p>\u0412\u0441\u0456 \u0442\u0435\u043c\u0438 \u0442\u0443\u0442 \u0454 \u0444\u0443\u043d\u0434\u0430\u043c\u0435\u043d\u0442\u043e\u043c \u0434\u043b\u044f \u043f\u043e\u0434\u0430\u043b\u044c\u0448\u0438\u0445 \u043f\u0440\u0430\u043a\u0442\u0438\u0447\u043d\u0438\u0445 \u0440\u043e\u0431\u0456\u0442 \u0437 Arduino Uno \u0442\u0430 \u0456\u043d\u0448\u0438\u043c\u0438 \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u0430\u043c\u0438.</p>"},{"location":"electronics/#_2","title":"\u0417\u0432\u2019\u044f\u0437\u043e\u043a \u0437 \u043f\u0440\u0430\u043a\u0442\u0438\u043a\u043e\u044e","text":"<p>\u0412\u0441\u0435, \u0449\u043e \u0432\u0438\u0432\u0447\u0430\u0454\u0442\u044c\u0441\u044f \u0442\u0443\u0442, \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0454\u0442\u044c\u0441\u044f \u0432: - \u043b\u0430\u0431\u043e\u0440\u0430\u0442\u043e\u0440\u043d\u0438\u0445 \u0440\u043e\u0431\u043e\u0442\u0430\u0445 \u0437 Arduino - \u0441\u0445\u0435\u043c\u0430\u0445 \u043f\u0456\u0434\u043a\u043b\u044e\u0447\u0435\u043d\u043d\u044f \u0434\u0430\u0442\u0447\u0438\u043a\u0456\u0432 - \u0440\u043e\u0431\u043e\u0442\u0456 \u0437 \u0446\u0438\u0444\u0440\u043e\u0432\u0438\u043c\u0438 \u0442\u0430 \u0430\u043d\u0430\u043b\u043e\u0433\u043e\u0432\u0438\u043c\u0438 \u0441\u0438\u0433\u043d\u0430\u043b\u0430\u043c\u0438 - \u043f\u0440\u043e\u0454\u043a\u0442\u0430\u0445 \u043d\u0430 \u0431\u0430\u0437\u0456 \u043c\u0456\u043a\u0440\u043e\u043a\u043e\u043d\u0442\u0440\u043e\u043b\u0435\u0440\u0456\u0432</p>"},{"location":"electronics/#_3","title":"\u0420\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u043e\u0432\u0430\u043d\u0438\u0439 \u043f\u043e\u0440\u044f\u0434\u043e\u043a \u0432\u0438\u0432\u0447\u0435\u043d\u043d\u044f :","text":"<ol> <li>\u0415\u043b\u0435\u043a\u0442\u0440\u0438\u0447\u043d\u0456 \u0432\u0435\u043b\u0438\u0447\u0438\u043d\u0438</li> <li>\u0417\u0430\u043a\u043e\u043d \u041e\u043c\u0430</li> <li>\u042f\u043a \u043e\u0431\u0456\u0439\u0442\u0438\u0441\u044f \u0431\u0435\u0437 \u043f\u0430\u0439\u043a\u0438? \u041c\u0430\u043a\u0435\u0442\u043d\u0430 \u043f\u043b\u0430\u0442\u0430 (Bradboard)</li> <li>\u0421\u0432\u0456\u0442\u043b\u043e\u0434\u0456\u043e\u0434\u0438</li> </ol>"},{"location":"electronics/breadboard/","title":"\u041c\u0430\u043a\u0435\u0442\u043d\u0430 \u043f\u043b\u0430\u0442\u0430 (Breadboard)","text":"<p>\u041c\u0435\u0442\u0430: \u041e\u0437\u043d\u0430\u0439\u043e\u043c\u0438\u0442\u0438\u0441\u044f \u0437 \u043f\u0440\u0438\u043d\u0446\u0438\u043f\u043e\u043c \u0440\u043e\u0431\u043e\u0442\u0438 \u043c\u0430\u043a\u0435\u0442\u043d\u043e\u0457 \u043f\u043b\u0430\u0442\u0438 \u0442\u0430 \u043d\u0430\u0432\u0447\u0438\u0442\u0438\u0441\u044f \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438 \u0457\u0457 \u0434\u043b\u044f \u0441\u043a\u043b\u0430\u0434\u0430\u043d\u043d\u044f \u0435\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u0438\u0445 \u0441\u0445\u0435\u043c \u0431\u0435\u0437 \u043f\u0430\u0439\u043a\u0438.</p>"},{"location":"electronics/breadboard/#breadboard_1","title":"\u041c\u0430\u043a\u0435\u0442\u043d\u0430 \u043f\u043b\u0430\u0442\u0430 (breadboard)","text":"<p>\u041c\u0430\u043a\u0435\u0442\u043d\u0430 \u043f\u043b\u0430\u0442\u0430 \u2014 \u0446\u0435 \u043f\u0440\u0438\u0441\u0442\u0440\u0456\u0439 \u0434\u043b\u044f \u0448\u0432\u0438\u0434\u043a\u043e\u0433\u043e \u0441\u043a\u043b\u0430\u0434\u0430\u043d\u043d\u044f \u0442\u0430 \u0442\u0435\u0441\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0435\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u0438\u0445 \u0441\u0445\u0435\u043c \u0431\u0435\u0437 \u043f\u0430\u0439\u043a\u0438.</p> <p>\u0412\u043e\u043d\u0430 \u0434\u043e\u0437\u0432\u043e\u043b\u044f\u0454 \u0431\u0430\u0433\u0430\u0442\u043e\u0440\u0430\u0437\u043e\u0432\u043e \u0437\u043c\u0456\u043d\u044e\u0432\u0430\u0442\u0438 \u0437\u2019\u0454\u0434\u043d\u0430\u043d\u043d\u044f \u043a\u043e\u043c\u043f\u043e\u043d\u0435\u043d\u0442\u0456\u0432 \u043f\u0456\u0434 \u0447\u0430\u0441 \u0440\u043e\u0437\u0440\u043e\u0431\u043a\u0438 \u0442\u0430 \u043d\u0430\u0432\u0447\u0430\u043d\u043d\u044f.</p> <p>\u041d\u0430 \u0440\u0438\u0441. 2 \u043f\u043e\u043a\u0430\u0437\u0430\u043d\u043e \u043c\u0430\u043b\u0443 \u043f\u043b\u0430\u0442\u0430 \u0442\u0430 \u0441\u0445\u0435\u043c\u0443 \u0432\u043d\u0443\u0442\u0440\u0456\u0448\u043d\u0456\u0445 \u0437\u2019\u0454\u0434\u043d\u0430\u043d\u044c \u043d\u0430 \u043d\u0456\u0439.</p> <p></p> \u041c\u0430\u043a\u0435\u0442\u043d\u0430 \u043f\u043b\u0430\u0442\u0430 \u043d\u0430 30 \u0440\u044f\u0434\u0456\u0432 (Breadbord): \u0432\u0438\u0433\u043b\u044f\u0434 \u0437\u0433\u043e\u0440\u0438 (\u0437\u043b\u0456\u0432\u0430) \u0442\u0430 \u0437\u2019\u0454\u0434\u043d\u0430\u043d\u043d\u044f \u043f\u0456\u043d\u0456\u0432 (\u0441\u043f\u0440\u0430\u0432\u0430)  <p>\u041a\u043e\u0436\u0435\u043d \u0440\u044f\u0434 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u0456\u0432 \u0432\u0441\u0435\u0440\u0435\u0434\u0438\u043d\u0456 \u043c\u0430\u043a\u0435\u0442\u043d\u043e\u0457 \u043f\u043b\u0430\u0442\u0438 \u0435\u043b\u0435\u043a\u0442\u0440\u0438\u0447\u043d\u043e \u0437\u2019\u0454\u0434\u043d\u0430\u043d\u0438\u0439.</p> <p>\u0426\u0435 \u043e\u0437\u043d\u0430\u0447\u0430\u0454, \u0449\u043e \u0435\u043b\u0435\u043c\u0435\u043d\u0442\u0438, \u0432\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u0456 \u0432 \u043e\u0434\u0438\u043d \u0440\u044f\u0434, \u0443\u0442\u0432\u043e\u0440\u044e\u044e\u0442\u044c \u043e\u0434\u0438\u043d \u0435\u043b\u0435\u043a\u0442\u0440\u0438\u0447\u043d\u0438\u0439 \u0432\u0443\u0437\u043e\u043b.</p> <p>\u041c\u0430\u043a\u0435\u0442\u043a\u0430 \u043f\u043b\u0430\u0442\u0430 \u0440\u043e\u0437\u0434\u0456\u043b\u0435\u043d\u0430 \u043d\u0430 \u0442\u0430\u043a \u043e\u043a\u0440\u0435\u043c\u0456 \u0437\u043e\u043d\u0438: 2 \u0437\u043e\u043d\u0438 \u0436\u0438\u0432\u043b\u0435\u043d\u043d\u044f (\u0441\u043f\u0440\u0430\u0432\u0430 \u0442\u0430 \u0437\u043b\u0456\u0432\u0430) \u0442\u0430 \u043e\u0441\u043d\u043e\u0432\u043d\u0430 \u0437\u043e\u043d\u0430 \u043f\u043e \u0446\u0435\u043d\u0442\u0440\u0443. \u041a\u043e\u043d\u0442\u0430\u043a\u0442\u0438 \u0432 \u043f\u0440\u0430\u0432\u0456\u0439 \u0456 \u043b\u0456\u0432\u0456\u0439 \u0447\u0430\u0441\u0442\u0438\u043d\u0430\u0445 \u043e\u0441\u043d\u043e\u0432\u043d\u043e\u0457 \u0437\u043e\u043d\u0438 \u043d\u0435 \u0437'\u0454\u0434\u043d\u0430\u043d\u0456 \u043c\u0456\u0436 \u0441\u043e\u0431\u043e\u044e, \u0442\u043e\u043c\u0443 \u043c\u0438 \u0439 \u043c\u0430\u0454\u043c\u043e \u043f\u043e 30 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u0456\u0432 \u0432 \u043a\u043e\u0436\u043d\u0456\u0439 \u0437\u043e\u043d\u0456 \u0442\u0430 2 \u043f\u0430\u0440\u0438 \\((+\\nobreakspace \u0456 \\nobreakspace-)\\) \u0448\u0438\u043d \u0436\u0438\u0432\u043b\u0435\u043d\u043d\u044f, \u0442\u043e\u0431\u0442\u043e:</p> \\[ 30\\cdot 2 + 2\\cdot 2 = 64 \\space \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u0438 \\] <p>\u041f\u0440\u0438\u0439\u043d\u044f\u0442\u043e \u043f\u0456\u0434'\u0454\u0434\u043d\u0443\u0432\u0430\u0442\u0438 <code>GND</code> \u043c\u0456\u043a\u0440\u043e\u043a\u043e\u043d\u0442\u0440\u043e\u043b\u043b\u0435\u0440\u0430 \u0434\u043e <code>-</code> breadboard, \u0430 <code>5V</code>/<code>3.3V</code> - \u0434\u043e <code>+</code></p>"},{"location":"electronics/breadboard/#_1","title":"\u0417\u2019\u0454\u0434\u043d\u0443\u0432\u0430\u043b\u044c\u043d\u0456 \u0434\u0440\u043e\u0442\u0438","text":"<p>\u0420\u0430\u0437\u043e\u043c \u0437 breadbord \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u044e\u0442\u044c \u0434\u0440\u043e\u0442\u0438 \u0434\u043b\u044f \u0437\u2019\u0454\u0434\u043d\u0430\u043d\u043d\u044f, \u044f\u043a\u0456 \u043c\u0430\u044e\u0442\u044c \u0441\u043f\u0435\u0446\u0456\u0430\u043b\u044c\u043d\u0456 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u0438 (\u0440\u0438\u0441. 3).</p> <p></p> \u041a\u043e\u043d\u0442\u0430\u043a\u0442\u0438 \u0434\u0440\u043e\u0442\u0456\u0432, \u044f\u043a\u0456 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u044e\u0442\u044c\u0441\u044f \u043f\u0440\u0438 \u0440\u043e\u0431\u043e\u0442\u0456 \u0437 breadbord: \u0442\u0438\u043f \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u0443, \u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0439 \u0437\u043b\u0456\u0432\u0430 \u043d\u0430\u0437\u0438\u0432\u0430\u0454\u0442\u044c\u0441\u044f \u00ab\u0442\u0430\u0442\u043e\u00bb, \u0441\u043f\u0440\u0430\u0432\u0430 \u00ab\u043c\u0430\u043c\u0430\u00bb  <p>\u0412\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u044e\u0447\u0438 \u0440\u0456\u0437\u043d\u0456 \u043a\u043e\u043c\u0431\u0456\u043d\u0430\u0446\u0456\u0457 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u0456\u0432 \u043c\u0430\u0454\u043c\u043e \u0442\u0440\u0438 \u0442\u0438\u043f\u0438 \u0434\u0440\u043e\u0442\u0456\u0432:</p> \u00ab\u0442\u0430\u0442\u043e-\u0442\u0430\u0442\u043e\u00bb \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0454\u0442\u044c\u0441\u044f \u0434\u043b\u044f \u0437'\u0454\u0434\u043d\u0430\u043d\u043d\u044f Ardino UNO \u0437 Breadboard \u00ab\u0442\u0430\u0442\u043e-\u043c\u0430\u043c\u0430\u00bb \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0454\u0442\u044c\u0441\u044f \u0434\u043b\u044f \u0437'\u0454\u0434\u043d\u0430\u043d\u043d\u044f Ardino UNO \u0430\u0431\u043e Breadboard \u0437 \u043c\u043e\u0434\u0443\u043b\u044f\u043c\u0438 \u0456 \u0434\u0430\u0442\u0447\u0438\u043a\u0430\u043c\u0438 \u00ab\u043c\u0430\u043c\u0430-\u043c\u0430\u043c\u0430\u00bb \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0454\u0442\u044c\u0441\u044f \u0434\u043b\u044f \u0437'\u0454\u0434\u043d\u0430\u043d\u043d\u044f \u043c\u043e\u0434\u0443\u043b\u0456\u0432 \u043c\u0456\u0436 \u0441\u043e\u0431\u043e\u044e, \u0430\u0431\u043e \u0434\u043b\u044f \u043f\u0456\u0434\u043a\u043b\u044e\u0447\u0435\u043d\u043d\u044f \u0434\u043e \u0456\u043d\u0448\u0438\u0445 \u043c\u0456\u043a\u0440\u043e\u043a\u043e\u043d\u0442\u0440\u043e\u043b\u043b\u0435\u0440\u0456\u0432, \u043d\u0430\u043f\u0440\u0438\u043a\u043b\u0430\u0434 Arduino Nano \u0430\u0431\u043e STM32"},{"location":"electronics/breadboard/#_2","title":"\u0412\u0438\u0441\u043d\u043e\u0432\u043e\u043a","text":"<p>\u041c\u0430\u043a\u0435\u0442\u043d\u0430 \u043f\u043b\u0430\u0442\u0430 \u0454 \u043e\u0441\u043d\u043e\u0432\u043d\u0438\u043c \u0456\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u043e\u043c \u0434\u043b\u044f \u043f\u0440\u043e\u0442\u043e\u0442\u0438\u043f\u0443\u0432\u0430\u043d\u043d\u044f \u0435\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u0438\u0445 \u0441\u0445\u0435\u043c \u0456 \u0434\u043e\u0437\u0432\u043e\u043b\u044f\u0454 \u0448\u0432\u0438\u0434\u043a\u043e \u0442\u0435\u0441\u0442\u0443\u0432\u0430\u0442\u0438 \u0456\u0434\u0435\u0457 \u0431\u0435\u0437 \u043f\u043e\u0448\u043a\u043e\u0434\u0436\u0435\u043d\u043d\u044f \u043a\u043e\u043c\u043f\u043e\u043d\u0435\u043d\u0442\u0456\u0432.</p> <p>\u0422\u0438\u043f\u043e\u0432\u0456 \u043f\u043e\u043c\u0438\u043b\u043a\u0438</p> <ul> <li>\u041f\u0456\u0434\u043a\u043b\u044e\u0447\u0435\u043d\u043d\u044f \u043a\u043e\u043c\u043f\u043e\u043d\u0435\u043d\u0442\u0456\u0432 \u0443 \u0440\u0456\u0437\u043d\u0456 \u0435\u043b\u0435\u043a\u0442\u0440\u0438\u0447\u043d\u0456 \u0433\u0440\u0443\u043f\u0438.</li> <li>\u041f\u0435\u0440\u0435\u043f\u043b\u0443\u0442\u0430\u043d\u0456 \u0448\u0438\u043d\u0438 \u0436\u0438\u0432\u043b\u0435\u043d\u043d\u044f (<code>+</code> \u0456 <code>\u2212</code>).</li> <li>\u0412\u0456\u0434\u0441\u0443\u0442\u043d\u0456\u0441\u0442\u044c \u0441\u043f\u0456\u043b\u044c\u043d\u043e\u0457 \u0437\u0435\u043c\u043b\u0456 (GND). \u0412\u0430\u0436\u043b\u0438\u0432\u043e \u043f\u0430\u043c'\u044f\u0442\u0430\u0442\u0438, \u0449\u043e \u043f\u0440\u0430\u0432\u0430 \u0456 \u043b\u0456\u0432\u0438 \u0448\u0438\u043d\u0438 \u0436\u0438\u0432\u043b\u0435\u043d\u043d\u044f \u043d\u0435 \u0437'\u0454\u0434\u043d\u0430\u043d\u0456 \u043c\u0456\u0436 \u0441\u043e\u0431\u043e\u044e</li> <li>\u0412\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u043d\u044f \u0434\u043e\u0432\u0433\u0438\u0445 \u043f\u0440\u043e\u0432\u043e\u0434\u0456\u0432 \u0431\u0435\u0437 \u043f\u043e\u0442\u0440\u0435\u0431\u0438.</li> </ul> <p>\u042f\u043a \u0434\u0443\u043c\u0430\u0442\u0438 \u043f\u0440\u043e breadboard</p> <p>\u041a\u043e\u0436\u0435\u043d \u0440\u044f\u0434 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u0456\u0432 = \u043e\u0434\u0438\u043d \u0435\u043b\u0435\u043a\u0442\u0440\u0438\u0447\u043d\u0438\u0439 \u0432\u0443\u0437\u043e\u043b \u042f\u043a\u0449\u043e \u0434\u0432\u0430 \u0435\u043b\u0435\u043c\u0435\u043d\u0442\u0438 \u0432 \u043e\u0434\u043d\u043e\u043c\u0443 \u0440\u044f\u0434\u0443 \u2192 \u0432\u043e\u043d\u0438 \u0435\u043b\u0435\u043a\u0442\u0440\u0438\u0447\u043d\u043e \u0437\u2019\u0454\u0434\u043d\u0430\u043d\u0456  </p>"},{"location":"stm32/","title":"STM32","text":"<p>\u041c\u0456\u043a\u0440\u043e\u043a\u043e\u043d\u0442\u0440\u043e\u043b\u0435\u0440\u0438 STM32 \u0442\u0430 \u0440\u043e\u0431\u043e\u0442\u0430 \u0437 \u043d\u0438\u043c\u0438 \u0447\u0435\u0440\u0435\u0437 CubeIDE.</p>"},{"location":"stm32/#_1","title":"\ud83d\udcda \u0422\u0435\u043c\u0438","text":"<ul> <li>GPIO \u2014 \u043f\u043e\u0440\u0442\u0438 \u0432\u0432\u043e\u0434\u0443/\u0432\u0438\u0432\u043e\u0434\u0443</li> </ul>"},{"location":"stm32/gpio/","title":"GPIO","text":"<p>GPIO \u2014 \u0446\u0435 \u0446\u0438\u0444\u0440\u043e\u0432\u0456 \u0432\u0445\u043e\u0434\u0438/\u0432\u0438\u0445\u043e\u0434\u0438.</p>"},{"location":"stm32/gpio/#odr","title":"ODR","text":"<p>ODR \u2014 Output Data Register. <pre><code>GPIOD-&gt;ODR ^= GPIO_PIN_12;\n</code></pre> \u0426\u0435 toggle LED.</p> <pre><code>#include &lt;stdio.h&gt;\n\nint main() {\n    printf(\"Hello STM32!\\n\");\n}\n</code></pre> <p>\u0422\u0435\u0441\u0442 \u0432\u0430\u043b\u043e\u0438\u0432\u043b\u0430\u043e\u0438 \u0432\u0430\u0432\u0430</p>"}]}